#!/usr/bin/env bash
# Vault post-commit dispatcher.
#
# Owned by the vault, NOT by any plug-in. Fires every executable file in
# `.githooks/post-commit.d/` after each commit. Plug-ins (vault-engine,
# lifestyle stack, future integrations) drop their own `<NN>-<plugin>.sh`
# script in that directory; the dispatcher walks them in lexical order
# so numeric prefixes (10-, 20-, …) define run sequence.
#
# Contract for plug-in scripts:
#   - exit 0 means success; non-zero exits are LOGGED but do NOT abort
#     the dispatcher (each plug-in is independent of the others)
#   - background work is fine; foreground work should be cheap (<1s)
#     because every commit pays the wait
#   - never edit the working tree — post-commit fires after the commit
#     is sealed, and creating new commits from inside the hook causes
#     loops or surprises
#
# Designed to be a no-op when no plug-ins are installed. Safe to keep
# even after every plug-in is removed.

set -u

# Find the vault root via git so plug-ins can rely on a consistent CWD.
VAULT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || exit 0
[ -z "$VAULT_ROOT" ] && exit 0

DISPATCH_DIR="$VAULT_ROOT/.githooks/post-commit.d"

# Empty-or-missing dispatch dir → no plug-ins → done.
[ -d "$DISPATCH_DIR" ] || exit 0

# Walk every executable file in lexical order. nullglob avoids the
# literal-glob fallback when the directory is empty.
shopt -s nullglob
for hook in "$DISPATCH_DIR"/*; do
  # Skip non-executable, non-files, and dotfiles.
  case "$(basename "$hook")" in .*) continue ;; esac
  [ -f "$hook" ] || continue
  [ -x "$hook" ] || continue
  # Run; failure is logged-only, not fatal. Capture rc before the test
  # so the log shows the plug-in's real exit code (not the if-! flip).
  "$hook"
  rc=$?
  if [ "$rc" -ne 0 ]; then
    echo "post-commit: plug-in failed: $(basename "$hook") (exit $rc)" >&2
  fi
done
shopt -u nullglob

exit 0
